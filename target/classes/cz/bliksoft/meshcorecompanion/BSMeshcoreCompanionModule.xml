<?xml version="1.0" encoding="UTF-8"?>
<root xmlns="http://bliksoft.cz/XmlFilesystem"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://bliksoft.cz/XmlFilesystem https://bliksoft.cz/schemas/XmlFilesystem.xsd">

	<file name="AppUI">
		<attribute name="root" value="main" />
		<file name="main" type="UIPane">
			<attribute name="theme" value="system" />
			<attribute name="title" value="BSMeshcoreCompanion" />
			<attribute name="minWidth" value="800" />
			<attribute name="minHeight" value="500" />

			<file name="topbar" type="VBox">
				<attribute name="spacing" value="0" />
				<attribute name="region" value="top" />
				<file name="toolbar" type="HBox" id="toolbar">
					<attribute name="spacing" value="0" />
					<file name="left" type="HBox" id="toolbar/left">
						<attribute name="FXclass" value="tool-bar" />
						<attribute name="hgrow" value="ALWAYS" />
						<attribute name="maxHeight" value="max" />
					</file>
					<file name="right" type="HBox" id="toolbar/right">
						<attribute name="FXclass" value="tool-bar" />
						<attribute name="maxHeight" value="max" />
						<file name="Connect" type="Button">
							<attribute name="action" value="ConnectAction" />
							<attribute name="focusTraversable" value="false" />
						</file>
						<file name="Disconnect" type="Button">
							<attribute name="action" value="DisconnectAction" />
							<attribute name="focusTraversable" value="false" />
						</file>
						<file name="Settings" type="Button">
							<attribute name="action" value="OpenSettingsAction" />
							<attribute name="focusTraversable" value="false" />
						</file>
						<file name="Save" type="Button">
							<attribute name="action" value="Save" />
							<attribute name="focusTraversable" value="false" />
						</file>
						<file name="Close" type="Button">
							<attribute name="action" value="Close" />
							<attribute name="focusTraversable" value="false" />
						</file>
						<file name="AppClose" type="Button">
							<attribute name="action" value="AppClose" />
							<attribute name="focusTraversable" value="false" />
						</file>
					</file>
				</file>
			</file>

			<file name="statusbar" type="HBox" id="statusbar">
				<attribute name="spacing" value="0" />
				<attribute name="region" value="bottom" />
				<attribute name="FXclass" value="bevel-raised" />
				<file name="connectionStatus" type="Class">
					<attribute name="class"
						value="cz.bliksoft.meshcorecompanion.controls.ConnectionStatusLabel" />
					<attribute name="FXclass" value="bevel-lowered" />
				</file>
				<file name="filler" type="StackPane">
					<attribute name="hgrow" value="SOMETIMES" />
				</file>
				<file name="contactsCount" type="Label" id="statusbar/contacts">
					<attribute name="text" value="Contacts: -" />
					<attribute name="FXclass" value="bevel-lowered" />
				</file>
				<file name="groupsCount" type="Label" id="statusbar/groups">
					<attribute name="text" value="Groups: -" />
					<attribute name="FXclass" value="bevel-lowered" />
				</file>
				<file name="statusbarMessage" type="Class">
					<attribute name="class"
						value="cz.bliksoft.javautils.app.ui.components.MessageStatusProvider" />
					<attribute name="FXclass" value="bevel-lowered" />
				</file>
			</file>
		</file>
	</file>

	<file name="core">
		<file name="actions">
			<file
				name="cz.bliksoft.javautils.app.ui.actions.basic.AppCloseAction" />
			<file
				name="cz.bliksoft.javautils.app.ui.actions.basic.SaveAction" />
			<file
				name="cz.bliksoft.javautils.app.ui.actions.basic.CloseAction" />
			<file name="cz.bliksoft.meshcorecompanion.actions.ConnectAction" />
			<file
				name="cz.bliksoft.meshcorecompanion.actions.DisconnectAction" />
			<file
				name="cz.bliksoft.meshcorecompanion.actions.OpenSettingsAction" />
		</file>
	</file>

	<include path="config/settings.xml" />

</root>
